# ─── Contact form email delivery ─────────────────────────────────────────────
# The email address that receives all contact form submissions
CONTACT_EMAIL=your@email.com

# Your Resend API key — get one free at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# (Optional) The "from" address shown in received emails.
# Free Resend accounts must use: "Something <onboarding@resend.dev>"
# Once you verify a domain on Resend, you can use your own:
# RESEND_FROM=PD Labs <hello@pdlabs.io>
RESEND_FROM=PD Labs <onboarding@resend.dev>
